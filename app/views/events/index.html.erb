<h1>Events</h1>

<h2>Upcoming events</h2>

<ul>
  <% @upcoming_events.each do |event| %>
    <li>
      <%= link_to event.title, event_path(event) %>
    </li>
  <% end %>
</ul>

<h2>Past events</h2>

<ul>
  <% @past_events.each do |event| %>
    <li>
      <%= link_to event.title, event_path(event) %>
    </li>
  <% end %>
</ul>